# App
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# Database
MONGO_URI=mongodb://localhost:27017/beamio

# Auth
JWT_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_SUCCESS_URL=http://localhost:3000/billing/success
STRIPE_CANCEL_URL=http://localhost:3000/billing/cancel

# Google Wallet
# For local dev, place credentials outside git and point to the file path.
GOOGLE_APPLICATION_CREDENTIALS=./.secrets/google-wallet-service-account.json
GOOGLE_ISSUER_ID=your_google_wallet_issuer_id
